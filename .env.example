# Copy to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local self-hosting)
DATABASE_URL="file:./dev.db"

# PostgreSQL (for production — uncomment and set)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/osha_recordkeeping?schema=public"

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_generate_a_strong_random_secret"
NEXTAUTH_URL="http://localhost:3000"

# ── Field-level encryption ────────────────────────────────────────────────────
# Field-level encryption key (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, PII is stored plaintext (development only — ALWAYS set in production)
FIELD_ENCRYPTION_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
